; PFC3D wall-symmetric / interior-random particle packing model
; Dimensions: 3 mm x 3 mm x 6 mm, centered at the origin.
; Run in the PFC Console with:
;   program call 'run_symmetric_pack.dat'

model new
model title '3x3x6 mm wall-symmetric random-interior particle packing'
model deterministic on
model random 10001
model domain extent -2.0 2.0 -2.0 2.0 -3.5 3.5
model largestrain on
model mechanical timestep safety-factor 0.8

; Contact model and default particle properties. Tune these for later tests.
contact cmat default model linear method deformability emod 1e7 kratio 1.25 property fric 0.25

; Six independently named finite walls. Top is inlet, bottom is outlet.
wall generate id 1 name 'inlet' group 'inlet' polygon ...
    (-1.5,-1.5, 3.0) ( 1.5,-1.5, 3.0) (-1.5, 1.5, 3.0) ( 1.5, 1.5, 3.0)
wall generate id 2 name 'outlet' group 'outlet' polygon ...
    (-1.5,-1.5,-3.0) (-1.5, 1.5,-3.0) ( 1.5,-1.5,-3.0) ( 1.5, 1.5,-3.0)
wall generate id 3 name 'wall_left' group 'wall_left' polygon ...
    (-1.5,-1.5,-3.0) (-1.5,-1.5, 3.0) (-1.5, 1.5,-3.0) (-1.5, 1.5, 3.0)
wall generate id 4 name 'wall_right' group 'wall_right' polygon ...
    ( 1.5,-1.5,-3.0) ( 1.5, 1.5,-3.0) ( 1.5,-1.5, 3.0) ( 1.5, 1.5, 3.0)
wall generate id 5 name 'wall_front' group 'wall_front' polygon ...
    (-1.5,-1.5,-3.0) ( 1.5,-1.5,-3.0) (-1.5,-1.5, 3.0) ( 1.5,-1.5, 3.0)
wall generate id 6 name 'wall_back' group 'wall_back' polygon ...
    (-1.5, 1.5,-3.0) (-1.5, 1.5, 3.0) ( 1.5, 1.5,-3.0) ( 1.5, 1.5, 3.0)

program call 'symmetric_pack.py' suppress

ball attribute density 2160.0 damp 0.8
model gravity 0 0 0

; Relax the assembly without gravity. Only wall-adjacent particles are
; mirror-constrained; interior particles remain random and can contact them.
; Increase cycles or tighten ratio for denser/stiffer packs.
model cycle 5000 calm 250
model solve ratio-average 1e-6 cycles-total 200000

; Re-project relaxed coordinates to exact wall-particle mirror symmetry and
; strict box bounds, then re-check and save.
program call 'symmetric_pack_project.py' suppress
program call 'symmetric_pack_check.py' suppress
model save 'symmetric_pack_porosity_0p40.sav'
program call 'export_pack_stl.py' suppress
program return
